// NME GYM - Prisma Schema for Neon (PostgreSQL)
// ================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ========== NextAuth Models (Phase 2 - pre-wired) ==========

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========== Core Business Models ==========

model User {
  id            String       @id @default(cuid())
  memberId      String?      @unique  // Human-readable member ID (e.g. NME-001)
  firstName     String?
  lastName      String?
  phone         String?      @unique
  email         String       @unique
  emailVerified DateTime?
  passwordHash  String?
  resetToken    String?      @unique
  resetTokenExpiry DateTime?
  image         String?
  role          String       @default("MEMBER") // MEMBER, ADMIN
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // Business relations
  memberships   Membership[]
  payments      Payment[]    @relation("UserPayments")
  verifiedPayments Payment[] @relation("AdminVerifiedPayments")
  bookings      Booking[]
  testimonials  Testimonial[]
}

model Membership {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  planTier   String     // STARTER, WARRIOR, ELITE
  status     String     @default("PENDING") // PENDING, ACTIVE, EXPIRED, CANCELLED
  startDate  DateTime?
  endDate    DateTime?
  reminder5DaySent Boolean @default(false)
  reminder1DaySent Boolean @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Payment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(10, 2)
  planName       String?  // Name of plan purchased (Monthly, 3 Months, etc.)
  admissionFee   Decimal? @db.Decimal(10, 2) // Admission fee for first-timers
  isFirstTimer   Boolean  @default(false) // Whether this is a first-time admission payment
  promoCode      String?  // The promo code used for this payment
  paymentMethod  String   // UPI, CARD, CASH
  screenshotUrl  String?
  status         String   @default("PENDING_VERIFICATION") // PENDING_VERIFICATION, VERIFIED, REJECTED
  verifiedById   String?
  verifiedBy     User?    @relation("AdminVerifiedPayments", fields: [verifiedById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Booking {
  id                String   @id @default(cuid())
  name              String?
  phone             String?
  age               Int?
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  interest          String
  preferredDate     DateTime
  preferredTimeSlot String
  status            String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  message           String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String
  content     String   @db.Text
  imageUrl    String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Trainer {
  id        String   @id @default(cuid())
  name      String
  role      String
  imageUrl  String?
  bio       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Facility {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  mediaUrl    String
  mediaType   String   @default("IMAGE") // IMAGE, VIDEO
  tag         String?  // New field for custom banners (e.g. "ELITE ZONE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Plan {
  id        String   @id @default(cuid())
  name      String   @unique // Monthly, 3 Months, etc.
  badge     String?  // STARTER, WARRIOR, ELITE, BEST VALUE, etc.
  price     Int
  period    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Offer {
  id          String    @id @default(cuid())
  title       String
  badge       String?
  discount    Int?
  promoCode   String?   @unique
  promoImage  String?
  description String?   @db.Text
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Settings {
  id              Int      @id @default(1)
  gymName         String   @default("NME GYM")
  logoUrl         String?  @default("/newlogo.png")
  address         String?  @default("Chumoukedima, Nagaland")
  whatsappNumber  String?  @default("+91 70053 10568")
  email           String?  @default("nmegym.india@gmail.com")
  instagramUrl    String?  @default("https://www.instagram.com/nme_gym")
  upiId           String?  @default("nme@upi")
  upiQrUrl        String?
  aboutText       String?  @db.Text
  aboutText2      String?  @db.Text
  openingHours    String?  @default("MON-SAT: 5:30 AM - 10:00 PM | SUN: 7:00 AM - 1:00 PM")
  heroBackgroundUrl String?
  aboutImage1Url    String?
  aboutImage2Url    String?
  aboutImage3Url    String?
  termsAndConditions String? @db.Text
  privacyPolicy      String? @db.Text
  refundPolicy       String? @db.Text
  admissionFee       Int      @default(1000)
  marqueeItem1      String?   @default("CARDIO SECTION")
  marqueeItem2      String?   @default("WEIGHTS AREA")
  marqueeItem3      String?   @default("POWER RACK ZONE")
  marqueeItem4      String?   @default("RESISTANCE SECTION")
  marqueeItem5      String?   @default("INDOOR TRACK")
  marqueeItem6      String?   @default("ZUMBA CLASSES")
  marqueeItem7      String?   @default("YOGA & FLEXIBILITY")
  updatedAt       DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  rating    Int      @default(5)
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
